PROJECT_NAME=ShortLink Service
VERSION=1.0.0
API_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shortlink

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

ELASTICSEARCH_HOSTS=["http://localhost:9200"]
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_SSL_VERIFY=true
ELASTICSEARCH_CA_CERTS=

ES_INDEX_PREFIX=clicks
ES_INDEX_ROLLOVER_DAYS=1
ES_WRITE_ALIAS=clicks-write
ES_SEARCH_ALIAS=clicks-search

SHORT_CODE_LENGTH=6
BASE_URL=http://localhost:8000

GEOIP2_DATABASE_PATH=./data/GeoLite2-City.mmdb

CACHE_TTL=3600
HOT_CACHE_TTL=7200
CACHE_WARMUP_INTERVAL=600
HOT_SHORTCODE_LIMIT=100
HOT_HOURS=1

SINGLEFLIGHT_TIMEOUT=5
SINGLEFLIGHT_LOCK_TTL=3

QR_VERSION=1
QR_ERROR_CORRECT=M
QR_BOX_SIZE=10
QR_BORDER=4
QR_FILL_COLOR=black
QR_BACK_COLOR=white

CSV_CHUNK_SIZE=10485760
DB_BATCH_SIZE=100
ES_BATCH_SIZE=500
MAX_UPLOAD_SIZE=1073741824
