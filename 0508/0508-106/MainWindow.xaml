<Window x:Class="CombatLogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:CombatLogAnalyzer"
        mc:Ignorable="d"
        Title="Combat Log Analyzer - 战斗日志分析器" 
        Height="900" 
        Width="1400"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <local:EventTypeConverter x:Key="EventTypeConverter"/>
        <local:HealthToColorConverter x:Key="HealthToColorConverter"/>
        <local:HealthPercentConverter x:Key="HealthPercentConverter"/>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnImport" Content="导入战斗日志" Width="120" Height="30" Click="btnImport_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnRefreshCache" Content="刷新缓存" Width="100" Height="30" Click="btnRefreshCache_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnClearCache" Content="清除所有缓存" Width="100" Height="30" Click="btnClearCache_Click" Margin="0,0,10,0"/>
            <Separator Width="20" Visibility="Hidden"/>
            <Button x:Name="btnExportPlayers" Content="导出玩家数据CSV" Width="140" Height="30" Click="btnExportPlayers_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnExportSkills" Content="导出技能数据CSV" Width="140" Height="30" Click="btnExportSkills_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnExportEvents" Content="导出全部事件CSV" Width="140" Height="30" Click="btnExportEvents_Click" IsEnabled="False"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtStatus" Grid.Column="0" Text="请导入战斗日志文件开始分析..." VerticalAlignment="Center" FontWeight="Bold"/>
            <ProgressBar x:Name="progressBar" Grid.Column="1" Width="200" Height="20" Minimum="0" Maximum="100" Visibility="Collapsed"/>
        </Grid>

        <TabControl Grid.Row="2" x:Name="tabControl">
            <TabItem Header="战斗统计">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Column="0" Grid.Row="0" Header="玩家统计（按伤害排序）" Margin="0,0,10,0">
                        <DataGrid x:Name="dgPlayerStats" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="玩家" Binding="{Binding PlayerName}" Width="120"/>
                                <DataGridTextColumn Header="总伤害" Binding="{Binding TotalDamage, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="DPS" Binding="{Binding DPS, StringFormat=F2}" Width="80"/>
                                <DataGridTextColumn Header="总治疗" Binding="{Binding TotalHealing, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="HPS" Binding="{Binding HPS, StringFormat=F2}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Grid.Row="0" Header="技能使用次数 Top 5（柱状图）">
                        <oxy:PlotView x:Name="plotView" Model="{Binding ChartModel}"/>
                    </GroupBox>

                    <GroupBox Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Header="最近战斗事件" Margin="0,10,0,0" Height="200">
                        <DataGrid x:Name="dgEvents" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="120"/>
                                <DataGridTextColumn Header="事件类型" Binding="{Binding EventType}" Width="150"/>
                                <DataGridTextColumn Header="施法者" Binding="{Binding Caster}" Width="120"/>
                                <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="120"/>
                                <DataGridTextColumn Header="技能" Binding="{Binding Skill}" Width="150"/>
                                <DataGridTextColumn Header="数值" Binding="{Binding Amount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding IsHeal, Converter={StaticResource EventTypeConverter}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="时间轴回放" x:Name="tabTimeline">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="时间轴控制" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPlay" Content="播放" Width="60" Height="30" Grid.Row="0" Grid.Column="0" Click="btnPlay_Click" Margin="0,0,10,0" IsEnabled="False"/>
                            <Button x:Name="btnPause" Content="暂停" Width="60" Height="30" Grid.Row="0" Grid.Column="0" Click="btnPause_Click" Margin="70,0,10,0" IsEnabled="False" Visibility="Collapsed"/>
                            <Button x:Name="btnStop" Content="停止" Width="60" Height="30" Grid.Row="0" Grid.Column="0" Click="btnStop_Click" Margin="140,0,10,0" IsEnabled="False"/>
                            
                            <TextBlock x:Name="txtCurrentTime" Grid.Row="0" Grid.Column="0" Margin="210,5,0,0" Text="时间: 00:00:00" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDuration" Grid.Row="0" Grid.Column="2" Text="总时长: 00:00:00" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            
                            <Slider x:Name="timelineSlider" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                                    Minimum="0" Maximum="100" Value="0" 
                                    SmallChange="1" LargeChange="10"
                                    ValueChanged="timelineSlider_ValueChanged"
                                    IsEnabled="False"
                                    Margin="0,10,0,0"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="当前时间点玩家状态" Margin="0,0,10,0">
                            <ScrollViewer>
                                <ItemsControl x:Name="playerStatusList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                                               Text="{Binding PlayerName}" 
                                                               FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                                               Text="{Binding Status}" 
                                                               FontWeight="Bold"
                                                               Foreground="{Binding HealthPercent, Converter={StaticResource HealthToColorConverter}}"/>

                                                    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                 Maximum="100" 
                                                                 Value="{Binding HealthPercent, Converter={StaticResource HealthPercentConverter}}"
                                                                 Height="15" Margin="0,5,0,0"
                                                                 Foreground="{Binding HealthPercent, Converter={StaticResource HealthToColorConverter}}"/>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="血量: " FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding CurrentHealth, StringFormat=N0}"/>
                                                        <TextBlock Text=" / "/>
                                                        <TextBlock Text="{Binding MaxHealth, StringFormat=N0}"/>
                                                        <TextBlock Text=" ("/>
                                                        <TextBlock Text="{Binding HealthPercent, StringFormat=F1}"/>
                                                        <TextBlock Text="%)"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="当前时间点附近事件">
                            <DataGrid x:Name="dgTimelineEvents" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="120"/>
                                    <DataGridTextColumn Header="类型" Binding="{Binding EventType}" Width="120"/>
                                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="100"/>
                                    <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="100"/>
                                    <DataGridTextColumn Header="技能" Binding="{Binding Skill}" Width="150"/>
                                    <DataGridTextColumn Header="数值" Binding="{Binding Amount, StringFormat=N0}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="回放速度" Margin="0,10,0,0" Height="60">
                        <StackPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
                            <TextBlock Text="速度: " VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton x:Name="rbSpeed05" Content="0.5x" GroupName="Speed" Checked="rbSpeed_Checked" Margin="0,0,10,0"/>
                            <RadioButton x:Name="rbSpeed1" Content="1x" GroupName="Speed" IsChecked="True" Checked="rbSpeed_Checked" Margin="0,0,10,0"/>
                            <RadioButton x:Name="rbSpeed2" Content="2x" GroupName="Speed" Checked="rbSpeed_Checked" Margin="0,0,10,0"/>
                            <RadioButton x:Name="rbSpeed5" Content="5x" GroupName="Speed" Checked="rbSpeed_Checked" Margin="0,0,10,0"/>
                            <RadioButton x:Name="rbSpeed10" Content="10x" GroupName="Speed" Checked="rbSpeed_Checked"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="statusBarText" Text="就绪"/>
        </StatusBar>
    </Grid>
</Window>
